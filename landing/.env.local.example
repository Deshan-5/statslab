# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it is git-ignored.

# ─── AI (Gemini) ─────────────────────────────────────────────────────────────
# Obtain from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-ai-api-key-here

# Optional: pin a specific model (defaults to gemini-flash-latest)
# GEMINI_MODEL=gemini-2.5-flash

# ─── NextAuth ────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://127.0.0.1:3005

# Generate with:  openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-output-of-openssl-rand-base64-32

# ─── Google OAuth ────────────────────────────────────────────────────────────
# https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── GitHub OAuth ────────────────────────────────────────────────────────────
# https://github.com/settings/applications/new
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ─── Supabase (optional — features degrade gracefully when missing) ──────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── Dev / Feature flags ─────────────────────────────────────────────────────
# Set to "true" ONLY in local dev to show the "Sign in as Guest" bypass button.
# Must be absent (or "false") in staging / production.
NEXT_PUBLIC_ENABLE_DEV_AUTH=true
